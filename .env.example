# ------------------------------------------------------------
# Required
# ------------------------------------------------------------
# Parent domain under which child apps are served
PARENT_DOMAIN=apps.bizapp.club

# Bootstrap admin — created the first time the app boots if no users exist
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Coolify API — used to attach new FQDNs to this application so Traefik
# routes them here and Let's Encrypt provisions TLS for them.
COOLIFY_API_URL=http://coolify:8080
COOLIFY_API_TOKEN=

# The UUID of THIS Coolify application (the deployer dashboard itself).
# Found in the Coolify UI -> Applications -> this app -> URL path.
COOLIFY_APP_UUID=

# ------------------------------------------------------------
# Optional
# ------------------------------------------------------------
PORT=3000
DATA_DIR=/data
